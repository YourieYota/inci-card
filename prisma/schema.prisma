// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- MODELE ROLES DYNAMIQUES ---
model CustomRole {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum CardType {
  BADGE
  CARTE_PRO
  RECU
}

// --- MODELES ---

// Utilisateurs de l'application (Personnel de l'Imprimerie Nationale)
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  login         String?  @unique
  passwordHash  String
  name          String
  firstName     String?
  phone         String?
  role          String   @default("OPERATEUR")
  createdAt     DateTime @default(now())
}

// Entreprises Clientes
model Company {
  id               String             @id @default(uuid())
  name             String             @unique
  identifierPrefix String?
  isLocked         Boolean            @default(false)
  isLaserEnabled   Boolean            @default(false)
  createdAt        DateTime           @default(now())
  
  // Relations
  employees      Employee[]
  templates      CardTemplate[]     // Une entreprise peut avoir plusieurs modèles
  cardFormats    CardFormat[]
  cardCategories CardCategory[]
  physicalTypes  CardPhysicalType[]
  deliveryBatches DeliveryBatch[]
}

// Employés des entreprises clientes
model Employee {
  id               String   @id @default(uuid())
  
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  dynamicData      Json     // Stocke la ligne Excel entière : {"Nom": "X", "Matricule": "Y"}
  uniqueIdentifier String   // Clé anti-doublon (ex: Matricule) choisie à l'import
  
  // La photo est strictement reliée à l'employé
  photoUrl         String?  // URL de l'image stockée sur le serveur (ex: S3)
  photoHash        String?  // Empreinte numérique de la photo (SHA-256)
  photoConflict    Boolean  @default(false) // Conflit de duplication photo suspecte
  enrollmentNumber String?  // Numéro d'enrôlement unique
  
  status           String   @default("A_ENROLER") // États : A_ENROLER, PHOTO_VALIDEE, IMPRIME, A_VERIFIER
  printedAt        DateTime? 
  enrolledBy       String?
  printedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  
  deliveryBatchId  String?
  deliveryBatch    DeliveryBatch? @relation(fields: [deliveryBatchId], references: [id], onDelete: SetNull)
  
  // Un employé est unique au sein de son entreprise
  @@unique([companyId, uniqueIdentifier]) 
}

// Modèles de conception (Studio Drag & Drop)
model CardTemplate {
  id            String   @id @default(uuid())
  
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  type          CardType @default(BADGE) // Permet de différencier Badges et Cartes Pro
  
  categoryId    String?
  category      CardCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  width         Int      @default(324) // Dimensions par défaut (CR80)
  height        Int      @default(204)
  backgroundUrl String?  // Image de fond de la carte
  
  layoutConfig  Json     // Tableau d'éléments: [{id, type, x, y, width, height, variableExcel}]

  @@unique([companyId, type, categoryId])
}

model CardFormat {
  id          String         @id @default(uuid())
  name        String
  width       Float          @default(85.6) // CR80 standard width (mm)
  height      Float          @default(53.98) // CR80 standard height (mm)
  unit        String         @default("mm") // mm, px, in
  companyId   String?
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categories  CardCategory[]

  @@unique([companyId, name])
}

model CardCategory {
  id          String         @id @default(uuid())
  name        String
  slug        String
  color       String         @default("#6366f1")
  description String?
  formatId    String
  format      CardFormat     @relation(fields: [formatId], references: [id], onDelete: Restrict)
  companyId   String?
  company     Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  templates   CardTemplate[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, slug])
}

model CardPhysicalType {
  id          String   @id @default(uuid())
  name        String
  slug        String
  description String?
  cardCode    String   @default("")
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, slug])
}

model DeliveryBatch {
  id          String   @id @default(uuid())
  batchNumber String?  @unique
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status      String   @default("PREPARE") // PREPARE, EN_TRANSIT, LIVRE
  employees   Employee[]
  shippedAt   DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}
